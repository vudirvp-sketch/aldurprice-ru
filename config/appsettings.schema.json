{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "AldurPrice appsettings",
  "type": "object",
  "properties": {
    "App": {
      "type": "object",
      "properties": {
        "Language": {
          "type": "string",
          "enum": ["auto", "ru", "en"],
          "default": "auto",
          "description": "UI language. auto = detect from OS culture."
        },
        "LogLevel": {
          "type": "string",
          "enum": ["Trace", "Debug", "Information", "Warning", "Error"],
          "default": "Information"
        },
        "BringToForeground": { "type": "boolean", "default": true },
        "AlwaysOnTop": { "type": "boolean", "default": false },
        "RememberDebugPanel": { "type": "boolean", "default": false },
        "CloseWithPoE2": { "type": "boolean", "default": false },
        "OpenWithPoE2": { "type": "boolean", "default": false },
        "AllOverlaysDisabled": { "type": "boolean", "default": false },
        "PricingOverlay": { "type": "boolean", "default": true },
        "Banner": { "type": "boolean", "default": true },
        "AdaptiveScanInterval": { "type": "boolean", "default": true },
        "PauseWhenUnfocused": { "type": "boolean", "default": true }
      }
    },
    "Pricing": {
      "type": "object",
      "properties": {
        "PricingSource": {
          "type": "string",
          "enum": ["poe2scout", "poe.ninja"],
          "default": "poe2scout"
        },
        "League": { "type": "string", "default": "Runes of Aldur" },
        "AutoPriceThresholds": { "type": "boolean", "default": true },
        "RedThreshold": { "type": "number", "minimum": 0, "default": 0.5 },
        "OrangeThreshold": { "type": "number", "minimum": 0, "default": 1.0 },
        "GreenThreshold": { "type": "number", "minimum": 0, "default": 5.0 },
        "DisplayCurrency": {
          "type": "string",
          "enum": ["exalt", "chaos"],
          "default": "exalt"
        },
        "DisplayCurrencySuffix": {
          "type": "string",
          "enum": ["en", "ru"],
          "default": "ru"
        },
        "CachePersistence": { "type": "boolean", "default": true },
        "StaleCacheTtlMinutes": { "type": "integer", "minimum": 5, "default": 60 }
      },
      "required": ["PricingSource", "League"]
    },
    "OCR": {
      "type": "object",
      "properties": {
        "Language": {
          "type": "string",
          "enum": ["eng", "rus", "deu", "fra", "spa", "por", "kor", "chi_tra"],
          "default": "rus"
        },
        "OcrBackend": {
          "type": "string",
          "enum": ["windows", "tesseract"],
          "default": "windows"
        },
        "CaptureMode": {
          "type": "string",
          "enum": ["printwindow", "desktop"],
          "default": "printwindow"
        },
        "SaveDebugImages": { "type": "boolean", "default": false },
        "DebugImageIntervalSeconds": { "type": "integer", "minimum": 1, "maximum": 30, "default": 15 },
        "DebugOverlay": { "type": "boolean", "default": false },
        "HideDebugOverlayWhenInterfaceNotDetected": { "type": "boolean", "default": false },
        "ScanIntervalMs": { "type": "integer", "minimum": 50, "maximum": 500, "default": 100 },
        "OverlayScale": { "type": ["number", "null"] },
        "EnableImagePreprocessing": { "type": "boolean", "default": true },
        "BinarizationThreshold": { "type": "integer", "minimum": 0, "maximum": 255, "default": 145 },
        "EnableTextColorFiltering": { "type": "boolean", "default": true },
        "TextColorTargetR": { "type": "integer", "minimum": 0, "maximum": 255, "default": 50 },
        "TextColorTargetG": { "type": "integer", "minimum": 0, "maximum": 255, "default": 42 },
        "TextColorTargetB": { "type": "integer", "minimum": 0, "maximum": 255, "default": 34 },
        "TextColorTolerance": { "type": "integer", "minimum": 0, "maximum": 255, "default": 47 },
        "TextColorMaxLuminance": { "type": "integer", "minimum": 0, "maximum": 255, "default": 145 },
        "TextColorMaxChannelSpread": { "type": "integer", "minimum": 0, "maximum": 255, "default": 29 },
        "OcrEngineMode": { "type": "integer", "minimum": 0, "maximum": 2, "default": 2 },
        "BypassOcrCache": { "type": "boolean", "default": false },
        "TesseractDataPath": { "type": "string", "default": "" },
        "FrameDiffing": { "type": "boolean", "default": true }
      }
    },
    "Translation": {
      "type": "object",
      "properties": {
        "RuneshapeCombinationsPath": {
          "type": "string",
          "default": "ocr/runeshape-combinations-ru.json"
        },
        "AutoUpdateFromExiledExchange": { "type": "boolean", "default": true }
      }
    },
    "Update": {
      "type": "object",
      "properties": {
        "AutoUpdate": { "type": "boolean", "default": true },
        "GithubToken": { "type": ["string", "null"] }
      }
    },
    "Window": {
      "type": "object",
      "properties": {
        "InitialSetupComplete": { "type": "boolean", "default": false },
        "CustomOffsetX": { "type": ["integer", "null"] },
        "CustomOffsetY": { "type": ["integer", "null"] },
        "CustomWidth": { "type": ["integer", "null"] },
        "CustomHeight": { "type": ["integer", "null"] }
      }
    }
  }
}
